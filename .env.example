# Copy to apps/api/.env.local and fill in. Never commit real secrets.

# --- Aura API (apps/api) ---
PORT=8787
# Optional: require clients to send Authorization: Bearer <same value>
# AURA_API_KEY=
DEV_USER_ID=user-1

# Trigger.dev (API uses this to call tasks.trigger; worker uses it for dev/deploy)
TRIGGER_SECRET_KEY=tr_dev_xxxxxxxx
# Project ref from Trigger.dev dashboard (also set in packages/trigger env when running CLI)
TRIGGER_PROJECT_REF=proj_aura_placeholder

# Claude (chat)
ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Gemini Flash (optional router before Claude)
GOOGLE_GENERATIVE_AI_API_KEY=
# GEMINI_ROUTER_MODEL=gemini-2.0-flash
# ENABLE_GEMINI_ROUTER=true

# --- Expo mobile (prefix EXPO_PUBLIC_ is bundled into the app) ---
# EXPO_PUBLIC_AURA_API_URL=http://127.0.0.1:8787
# Use your machine LAN IP for a physical device, or 10.0.2.2 for Android emulator host.
# EXPO_PUBLIC_AURA_API_KEY=must_match_AURA_API_KEY_if_set

# --- OpenRouter (optional) ---
# OPENROUTER_API_KEY=
# OPENROUTER_GEMINI_ROUTER_MODEL=google/gemini-2.0-flash-001
# OPENROUTER_CLAUDE_COPILOT_MODEL=anthropic/claude-sonnet-4
