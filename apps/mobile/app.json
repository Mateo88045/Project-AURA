{
  "expo": {
    "name": "Chronos",
    "slug": "chronos",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "chronos",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A1118"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.chronos.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Chronos uses the camera to capture photos of your assignments so they can be added to your schedule.",
        "NSUserNotificationsUsageDescription": "Chronos sends reminders for your scheduled study blocks and daily assignment updates.",
        "UIBackgroundModes": ["remote-notification"],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A1118"
      },
      "package": "com.chronos.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.VIBRATE"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-apple-authentication",
      [
        "expo-camera",
        {
          "cameraPermission": "Chronos uses the camera to capture photos of your assignments so they can be added to your schedule.",
          "recordAudioAndroid": false
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#A8DADC"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": ""
      },
      "supabaseUrl": "https://bvwumzzuvubiacueftbz.supabase.co",
      "supabasePublishableKey": "sb_publishable_if5RMKHlwHLzUu97PaAcbQ_Vgm-rb7u",
      "supportUrl": "https://chronos-app.com/support",
      "privacyPolicyUrl": "https://chronos-app.com/privacy",
      "termsUrl": "https://chronos-app.com/terms"
    }
  }
}
