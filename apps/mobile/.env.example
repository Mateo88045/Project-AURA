# Chronos mobile — copy to `.env` (gitignored) and fill in.
# Only EXPO_PUBLIC_* vars are exposed to the app bundle.
#
# NOTE: The Supabase URL/key and the AI API URL/key also have fallbacks in
# app.json `extra`, so the app runs without this file. Use .env to override
# per-developer or for EAS build profiles.

# ── Supabase (public client credentials) ────────────────────────────────────
EXPO_PUBLIC_SUPABASE_URL=https://bvwumzzuvubiacueftbz.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_if5RMKHlwHLzUu97PaAcbQ_Vgm-rb7u

# ── Chronos AI API (apps/api) ───────────────────────────────────────────────
# Deployed URL of apps/api (e.g. https://chronos-api.onrender.com). Leave as the
# localhost default for simulator testing against a local `pnpm --filter @chronos/api dev`.
EXPO_PUBLIC_AURA_API_URL=http://127.0.0.1:8787
# Must match AURA_API_KEY in apps/api/.env.local.
EXPO_PUBLIC_AURA_API_KEY=

# ── RevenueCat (in-app purchases / paywall) ─────────────────────────────────
# iOS public SDK key from the RevenueCat dashboard. Until this is set the
# paywall runs in PREVIEW mode (no charge). See apps/mobile/services/purchases.ts.
EXPO_PUBLIC_REVENUECAT_IOS_KEY=
