# Copy to .env.local in this directory (apps/api)

PORT=8787
AURA_API_KEY=
DEV_USER_ID=user-1

TRIGGER_SECRET_KEY=

# OpenRouter (optional; used for both Gemini Flash routing + Claude Sonnet copilot)
OPENROUTER_API_KEY=
OPENROUTER_GEMINI_ROUTER_MODEL=google/gemini-2.0-flash-001
OPENROUTER_CLAUDE_COPILOT_MODEL=anthropic/claude-sonnet-4

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_ROUTER_MODEL=gemini-2.0-flash
# Vision model for photo OCR (/v1/ocr — "Snap a homework page"). Requires
# GOOGLE_GENERATIVE_AI_API_KEY above.
GEMINI_VISION_MODEL=gemini-2.0-flash
ENABLE_GEMINI_ROUTER=true

# Soft per-user daily copilot message cap (cost guardrail). 0 = unlimited.
# Entry-tier limit; raise/skip for `pro` once RevenueCat entitlements are wired.
COPILOT_DAILY_MESSAGE_CAP=40

# NOTE: AURA_API_KEY above must equal EXPO_PUBLIC_AURA_API_KEY in apps/mobile/.env,
# and the deployed URL of this server must be set as EXPO_PUBLIC_AURA_API_URL.
