# Copy to .env.local in this directory (apps/api)

PORT=8787
AURA_API_KEY=
DEV_USER_ID=user-1

TRIGGER_SECRET_KEY=

# OpenRouter (optional; used for both Gemini Flash routing + Claude Sonnet copilot)
OPENROUTER_API_KEY=
OPENROUTER_GEMINI_ROUTER_MODEL=google/gemini-2.0-flash-001
OPENROUTER_CLAUDE_COPILOT_MODEL=anthropic/claude-sonnet-4

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

GOOGLE_GENERATIVE_AI_API_KEY=
GEMINI_ROUTER_MODEL=gemini-2.0-flash
ENABLE_GEMINI_ROUTER=true
